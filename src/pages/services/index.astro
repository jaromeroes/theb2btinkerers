---
import Base from '../../layouts/Base.astro';
---
<Base title="B2B Marketing Services | The B2B Tinkerers" description="Six ways we help B2B tech and industrial companies get more from marketing. Strategy, positioning, GTM, AI, and fractional leadership for mid-market companies.">

<!-- HERO -->
<section class="sh-hero">
  <div class="sh-hero-inner">
    <div class="sh-eyebrow">What we do</div>
    <h1 class="sh-h1">Six ways we turn marketing into a growth engine.</h1>
    <p class="sh-subtitle">We help B2B tech and industrial companies get more from marketing without spending more. Each engagement starts with understanding your business. The strategy follows.</p>
  </div>
</section>

<!-- SERVICES GRID -->
<section class="sh-grid-section">
  <div class="sh-grid">
    <a class="sh-card" href="/services/marketing-audit">
      <span class="sh-num">01</span>
      <div class="sh-title">Marketing Audit</div>
      <div class="sh-body">Honest assessment of where you are: positioning, team, budget, and alignment with business goals.</div>
      <span class="sh-more">Learn more &rarr;</span>
    </a>
    <a class="sh-card" href="/services/brand-strategy">
      <span class="sh-num">02</span>
      <div class="sh-title">Brand Strategy &amp; Positioning</div>
      <div class="sh-body">Define what you stand for, who you're for, and why someone should choose you. The foundation.</div>
      <span class="sh-more">Learn more &rarr;</span>
    </a>
    <a class="sh-card" href="/services/go-to-market">
      <span class="sh-num">03</span>
      <div class="sh-title">Go-To-Market Strategy</div>
      <div class="sh-body">A clear GTM motion that connects your positioning to pipeline. Channels, messages, timing.</div>
      <span class="sh-more">Learn more &rarr;</span>
    </a>
    <a class="sh-card" href="/services/marketing-plan">
      <span class="sh-num">04</span>
      <div class="sh-title">Marketing Plan &amp; Business Alignment</div>
      <div class="sh-body">A marketing plan that reflects real business objectives and that your team will actually follow.</div>
      <span class="sh-more">Learn more &rarr;</span>
    </a>
    <a class="sh-card" href="/services/ai-strategy">
      <span class="sh-num">05</span>
      <div class="sh-title">AI &amp; Hybrid Marketing Strategy</div>
      <div class="sh-body">The future marketing team is not fully human nor fully automated. We help you define the hybrid model.</div>
      <span class="sh-more">Learn more &rarr;</span>
    </a>
    <a class="sh-card" href="/services/fractional-cmo">
      <span class="sh-num">06</span>
      <div class="sh-title">Fractional CMO</div>
      <div class="sh-body">Senior marketing leadership without the full-time cost. We lead your team and maintain direction.</div>
      <span class="sh-more">Learn more &rarr;</span>
    </a>
  </div>
</section>

<!-- CTA BANNER -->
<section class="sh-cta">
  <div class="sh-cta-inner">
    <h2 class="sh-cta-h2">Not sure which service fits? Let's figure it out together.</h2>
    <p class="sh-cta-subtitle">Every engagement starts with a conversation. No pitch. No commitment. Just an honest look at where you are and where you could be.</p>
    <a class="btn-primary" href="#contact">Let's talk &rarr;</a>
  </div>
</section>

</Base>

<style>
/* HERO */
.sh-hero{padding:calc(68px + clamp(60px,8vw,100px)) var(--pad) clamp(64px,8vw,96px);background:var(--forest);position:relative;overflow:hidden}
.sh-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 80% 20%,rgba(212,232,74,0.07) 0%,transparent 55%);pointer-events:none}
.sh-hero-inner{max-width:800px;position:relative;z-index:1}
.sh-eyebrow{font-size:9px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:var(--lime);opacity:.65;display:flex;align-items:center;gap:10px;margin-bottom:22px}
.sh-eyebrow::before{content:'';display:block;width:18px;height:1px;background:var(--lime)}
.sh-h1{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(30px,5vw,64px);font-weight:800;letter-spacing:-0.04em;line-height:.97;color:var(--cream);margin-bottom:20px}
.sh-subtitle{font-size:clamp(14px,1.8vw,17px);line-height:1.8;color:rgba(245,240,232,0.60);max-width:520px}

/* GRID */
.sh-grid-section{padding:clamp(72px,9vw,112px) var(--pad);background:var(--cream)}
.sh-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
@media(max-width:900px){.sh-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:520px){.sh-grid{grid-template-columns:1fr}}

/* CARDS */
.sh-card{background:var(--forest);padding:clamp(24px,3vw,36px) clamp(20px,2.5vw,32px);position:relative;transition:background .2s;cursor:pointer;text-decoration:none;display:block}
.sh-card:hover{background:var(--lime)}
.sh-card:hover .sh-num{color:var(--forest);opacity:.22}
.sh-card:hover .sh-title{color:var(--forest)}
.sh-card:hover .sh-body{color:rgba(28,74,58,.65)}
.sh-card:hover .sh-more{color:var(--forest);opacity:1}
.sh-num{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:40px;font-weight:800;color:var(--cream);opacity:.15;display:block;line-height:1;margin-bottom:6px;transition:color .2s,opacity .2s}
.sh-title{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(14px,1.8vw,17px);font-weight:700;color:var(--cream);margin-bottom:10px;line-height:1.3;transition:color .2s}
.sh-body{font-size:12.5px;line-height:1.7;color:rgba(245,240,232,.68);transition:color .2s;padding-bottom:28px}
.sh-more{font-size:11px;font-weight:700;letter-spacing:.04em;color:var(--lime);opacity:.6;position:absolute;bottom:20px;left:clamp(20px,2.5vw,32px);transition:color .2s,opacity .2s}

/* CTA BANNER */
.sh-cta{padding:clamp(72px,9vw,112px) var(--pad);background:var(--forest)}
.sh-cta-inner{max-width:660px}
.sh-cta-h2{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(26px,4vw,48px);font-weight:800;letter-spacing:-0.04em;line-height:.97;color:var(--cream);margin-bottom:20px}
.sh-cta-subtitle{font-size:clamp(13px,1.5vw,16px);line-height:1.8;color:rgba(245,240,232,.45);margin-bottom:36px}
</style>
