---
import Base from '../../layouts/Base.astro';
---
<Base title="B2B Marketing Services | The B2B Tinkerers" description="Six ways we help B2B tech and industrial companies build marketing that works. Strategy, positioning, GTM, and senior leadership without the agency overhead.">

<!-- HERO -->
<section class="services-hero">
  <div class="services-hero-inner">
    <div class="services-eyebrow">What we do</div>
    <h1 class="services-h1">Six ways we connect marketing to the business. And make it stick.</h1>
    <p class="services-subtitle">We help B2B tech and industrial companies build marketing that works. Not just marketing that exists.</p>
  </div>
</section>

<!-- SERVICES GRID -->
<section class="services-grid-section">
  <div class="services-grid">
    <a class="svc-card" href="/services/marketing-audit">
      <span class="svc-num">01</span>
      <div class="svc-title">Marketing Audit</div>
      <div class="svc-body">Honest assessment of where you are: positioning, team, budget, and alignment with business goals.</div>
      <span class="svc-more">Learn more &rarr;</span>
    </a>
    <a class="svc-card" href="/services/brand-strategy">
      <span class="svc-num">02</span>
      <div class="svc-title">Brand Strategy & Positioning</div>
      <div class="svc-body">Define what you stand for, who you're for, and why someone should choose you. The foundation.</div>
      <span class="svc-more">Learn more &rarr;</span>
    </a>
    <a class="svc-card" href="/services/go-to-market">
      <span class="svc-num">03</span>
      <div class="svc-title">Go-To-Market Strategy</div>
      <div class="svc-body">A clear GTM motion that connects your positioning to pipeline. Channels, messages, timing. Aligned.</div>
      <span class="svc-more">Learn more &rarr;</span>
    </a>
    <a class="svc-card" href="/services/marketing-plan">
      <span class="svc-num">04</span>
      <div class="svc-title">Marketing Plan & Business Alignment</div>
      <div class="svc-body">A marketing plan that reflects real business objectives. One your team will actually follow.</div>
      <span class="svc-more">Learn more &rarr;</span>
    </a>
    <a class="svc-card" href="/services/ai-strategy">
      <span class="svc-num">05</span>
      <div class="svc-title">AI & Hybrid Marketing Strategy</div>
      <div class="svc-body">The future marketing team is not fully human, nor fully automated. We help you define the hybrid model.</div>
      <span class="svc-more">Learn more &rarr;</span>
    </a>
    <a class="svc-card" href="/services/fractional-cmo">
      <span class="svc-num">06</span>
      <div class="svc-title">Fractional CMO</div>
      <div class="svc-body">Senior marketing leadership without the full-time cost. We lead your team and maintain direction.</div>
      <span class="svc-more">Learn more &rarr;</span>
    </a>
  </div>
</section>

<!-- CTA -->
<section class="services-cta">
  <div class="services-cta-inner">
    <h2 class="services-cta-h2">Not sure which service fits? Let's figure it out together.</h2>
    <a class="btn-primary" href="/#contact">Let's talk &rarr;</a>
  </div>
</section>

</Base>

<style>
/* HERO */
.services-hero{padding:calc(68px + clamp(60px,8vw,100px)) var(--pad) clamp(64px,8vw,96px);background:var(--forest);position:relative;overflow:hidden}
.services-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 80% 20%,rgba(212,232,74,0.07) 0%,transparent 55%);pointer-events:none}
.services-hero-inner{max-width:800px;position:relative;z-index:1}
.services-eyebrow{font-size:9px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:var(--lime);opacity:.65;display:flex;align-items:center;gap:10px;margin-bottom:22px}
.services-eyebrow::before{content:'';display:block;width:18px;height:1px;background:var(--lime)}
.services-h1{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(30px,5vw,64px);font-weight:800;letter-spacing:-0.04em;line-height:.97;color:var(--cream);margin-bottom:20px}
.services-subtitle{font-size:clamp(14px,1.8vw,17px);line-height:1.8;color:rgba(245,240,232,0.60);max-width:520px}

/* GRID */
.services-grid-section{padding:clamp(72px,9vw,112px) var(--pad);background:var(--cream)}
.services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
@media(max-width:900px){.services-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:520px){.services-grid{grid-template-columns:1fr}}

/* CARDS */
.svc-card{background:var(--forest);padding:clamp(24px,3vw,36px) clamp(20px,2.5vw,32px);position:relative;transition:background .2s;cursor:pointer;text-decoration:none;display:block}
.svc-card:hover{background:var(--lime)}
.svc-card:hover .svc-num{color:var(--forest);opacity:.22}
.svc-card:hover .svc-title{color:var(--forest)}
.svc-card:hover .svc-body{color:rgba(28,74,58,.65)}
.svc-card:hover .svc-more{color:var(--forest);opacity:1}
.svc-num{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:40px;font-weight:800;color:var(--cream);opacity:.15;display:block;line-height:1;margin-bottom:6px;transition:color .2s,opacity .2s}
.svc-title{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(14px,1.8vw,17px);font-weight:700;color:var(--cream);margin-bottom:10px;line-height:1.3;transition:color .2s}
.svc-body{font-size:12.5px;line-height:1.7;color:rgba(245,240,232,.68);transition:color .2s;padding-bottom:28px}
.svc-more{font-size:11px;font-weight:700;letter-spacing:.04em;color:var(--lime);opacity:.6;position:absolute;bottom:20px;left:clamp(20px,2.5vw,32px);transition:color .2s,opacity .2s}

/* CTA */
.services-cta{padding:clamp(72px,9vw,112px) var(--pad);background:var(--forest)}
.services-cta-inner{max-width:660px}
.services-cta-h2{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(26px,4vw,48px);font-weight:800;letter-spacing:-0.04em;line-height:.97;color:var(--cream);margin-bottom:32px}
</style>
