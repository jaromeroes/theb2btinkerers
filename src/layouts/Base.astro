---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
}

const {
  title,
  description = 'B2B Marketing Strategy Consultancy. We help B2B tech and industrial companies get more from marketing — without spending more.',
  ogImage = '/og-default.png',
  canonicalURL = Astro.url.href,
} = Astro.props;

const siteName = 'The B2B Tinkerers';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="index, follow" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content={siteName} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

<!-- NAV -->
<nav class="nav" id="main-nav">
  <div class="nav-inner">
    <a class="nav-logo" href="/">The B2B <span>Tinkerers</span></a>
    <div class="nav-links">
      <a class={`nav-link${currentPath.includes('services') ? ' active' : ''}`} href="/#services">Services</a>
      <a class={`nav-link${currentPath.includes('method') ? ' active' : ''}`} href="/#method">Method</a>
      <a class={`nav-link${currentPath.startsWith('/insights') ? ' active' : ''}`} href="/insights">Insights</a>
      <a class={`nav-link${currentPath === '/about' ? ' active' : ''}`} href="/about">About</a>
    </div>
    <a class="nav-cta" href="mailto:hello@theb2btinkerers.com">Book a call →</a>
    <button class="nav-burger" id="nav-burger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="nav-mobile" id="nav-mobile">
    <a class="nav-mobile-link" href="/#services">Services</a>
    <a class="nav-mobile-link" href="/#method">Method</a>
    <a class="nav-mobile-link" href="/insights">Insights</a>
    <a class="nav-mobile-link" href="/about">About</a>
    <a class="nav-mobile-cta" href="mailto:hello@theb2btinkerers.com">Book a discovery call →</a>
  </div>
</nav>

<slot />

<!-- CONTACT FORM -->
<section class="contact-section" id="contact">
  <div class="contact-inner">
    <div class="contact-left">
      <div class="contact-eyebrow">Work with us</div>
      <h2 class="contact-h2">Ready to talk?</h2>
      <p class="contact-body">Tell us a bit about your company and what you're trying to solve. We'll get back to you within 24 hours.</p>
      <div class="contact-direct">
        <span class="contact-or">Or email us directly</span>
        <a class="contact-email" href="mailto:hello@theb2btinkerers.com">hello@theb2btinkerers.com</a>
      </div>
    </div>
    <div class="contact-right">
      <form class="contact-form" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="name">Your name</label>
            <input class="form-input" type="text" id="name" name="name" placeholder="Jane Smith" required />
          </div>
          <div class="form-group">
            <label class="form-label" for="company">Company</label>
            <input class="form-input" type="text" id="company" name="company" placeholder="Acme B2B" required />
          </div>
        </div>
        <div class="form-group">
          <label class="form-label" for="email">Work email</label>
          <input class="form-input" type="email" id="email" name="email" placeholder="jane@company.com" required />
        </div>
        <div class="form-group">
          <label class="form-label" for="message">What are you trying to solve?</label>
          <textarea class="form-textarea" id="message" name="message" placeholder="Tell us about your current situation and what you're looking for..." rows="4" required></textarea>
        </div>
        <button class="form-submit" type="submit">Send message →</button>
        <p class="form-disclaimer">We'll respond within 24 hours. No spam, no pitch decks.</p>
      </form>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-top">
      <a class="footer-logo" href="/">The B2B <span>Tinkerers</span></a>
      <p class="footer-tagline">Senior B2B marketing strategy,<br>without the agency overhead.</p>
    </div>
    <div class="footer-mid">
      <div class="footer-col">
        <span class="footer-col-label">Services</span>
        <a class="footer-link" href="/#services">Marketing Audit</a>
        <a class="footer-link" href="/#services">Brand Strategy</a>
        <a class="footer-link" href="/#services">Go-To-Market</a>
        <a class="footer-link" href="/#services">Fractional CMO</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-label">Company</span>
        <a class="footer-link" href="/about">About</a>
        <a class="footer-link" href="/insights">Insights</a>
        <a class="footer-link" href="#contact">Contact</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-label">Get in touch</span>
        <a class="footer-link" href="mailto:hello@theb2btinkerers.com">hello@theb2btinkerers.com</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span class="footer-copy">© {new Date().getFullYear()} The B2B Tinkerers. All rights reserved.</span>
    </div>
  </div>
</footer>

</body>
</html>

<script>
const nav = document.getElementById('main-nav');
window.addEventListener('scroll', () => {
  nav?.classList.toggle('scrolled', window.scrollY > 20);
}, { passive: true });

const burger = document.getElementById('nav-burger');
const mobile = document.getElementById('nav-mobile');
burger?.addEventListener('click', () => {
  burger.classList.toggle('open');
  mobile?.classList.toggle('open');
});
</script>

<style>
.nav{position:fixed;top:0;left:0;right:0;z-index:200;background:var(--forest);border-bottom:1px solid rgba(212,232,74,0.08);transition:box-shadow .2s}
.nav.scrolled{box-shadow:0 4px 32px rgba(0,0,0,0.25)}
.nav-inner{padding:0 var(--pad);display:flex;align-items:center;justify-content:space-between;height:68px;gap:32px}
.nav-logo{font-family:'Bricolage Grotesque',sans-serif;font-size:17px;font-weight:800;letter-spacing:-0.03em;color:var(--cream);white-space:nowrap;text-decoration:none;flex-shrink:0}
.nav-logo span{color:var(--lime)}
.nav-links{display:flex;gap:clamp(16px,3vw,32px);align-items:center}
@media(max-width:700px){.nav-links{display:none}}
.nav-link{font-size:13px;font-weight:500;color:rgba(245,240,232,0.6);text-decoration:none;transition:color .15s;padding:4px 0;border-bottom:2px solid transparent;transition:color .15s, border-color .15s}
.nav-link:hover,.nav-link.active{color:var(--cream);border-bottom-color:var(--lime)}
.nav-cta{background:var(--lime);color:var(--forest);font-family:'Inter',sans-serif;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:10px 20px;text-decoration:none;transition:opacity .15s;white-space:nowrap;flex-shrink:0}
.nav-cta:hover{opacity:.85}
@media(max-width:700px){.nav-cta{display:none}}
.nav-burger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:8px;flex-shrink:0}
@media(max-width:700px){.nav-burger{display:flex}}
.nav-burger span{display:block;width:22px;height:2px;background:var(--cream);transition:transform .2s,opacity .2s}
.nav-burger.open span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.nav-burger.open span:nth-child(2){opacity:0}
.nav-burger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
.nav-mobile{display:none;flex-direction:column;background:var(--forest);border-top:1px solid rgba(255,255,255,.06);padding:16px var(--pad) 24px}
.nav-mobile.open{display:flex}
.nav-mobile-link{font-size:15px;font-weight:500;color:rgba(245,240,232,.65);text-decoration:none;padding:13px 0;border-bottom:1px solid rgba(255,255,255,.05)}
.nav-mobile-link:hover{color:var(--cream)}
.nav-mobile-cta{margin-top:16px;background:var(--lime);color:var(--forest);font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:14px 20px;text-decoration:none;text-align:center}

.contact-section{background:var(--linen);padding:clamp(64px,9vw,108px) var(--pad)}
.contact-inner{display:grid;grid-template-columns:1fr 1.4fr;gap:clamp(40px,7vw,96px);align-items:start;max-width:1080px;margin:0 auto}
@media(max-width:820px){.contact-inner{grid-template-columns:1fr}}
.contact-eyebrow{font-size:9px;font-weight:700;letter-spacing:0.25em;text-transform:uppercase;color:var(--forest);opacity:.4;display:flex;align-items:center;gap:10px;margin-bottom:16px}
.contact-eyebrow::before{content:'';display:block;width:14px;height:1px;background:currentColor}
.contact-h2{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(28px,4vw,48px);font-weight:800;letter-spacing:-0.04em;line-height:.97;color:var(--forest);margin-bottom:16px}
.contact-body{font-size:clamp(13px,1.5vw,15px);line-height:1.8;color:var(--gray);margin-bottom:28px}
.contact-direct{display:flex;flex-direction:column;gap:6px}
.contact-or{font-size:10px;color:rgba(28,74,58,.4);text-transform:uppercase;letter-spacing:.1em;font-weight:600}
.contact-email{font-size:15px;font-weight:600;color:var(--forest);text-decoration:none;border-bottom:2px solid rgba(28,74,58,.2);padding-bottom:2px;display:inline-block;transition:border-color .15s}
.contact-email:hover{border-color:var(--forest)}
.contact-form{display:flex;flex-direction:column;gap:16px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
@media(max-width:480px){.form-row{grid-template-columns:1fr}}
.form-group{display:flex;flex-direction:column;gap:6px}
.form-label{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:rgba(28,74,58,.55)}
.form-input,.form-textarea{background:var(--cream);border:1.5px solid rgba(28,74,58,.18);padding:12px 14px;font-family:'Inter',sans-serif;font-size:14px;color:var(--ink);outline:none;transition:border-color .15s;resize:none;width:100%;box-sizing:border-box}
.form-input:focus,.form-textarea:focus{border-color:var(--forest)}
.form-input::placeholder,.form-textarea::placeholder{color:rgba(28,74,58,.28)}
.form-submit{background:var(--forest);color:var(--cream);font-family:'Inter',sans-serif;font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:15px 28px;border:none;cursor:pointer;transition:opacity .15s;align-self:flex-start}
.form-submit:hover{opacity:.85}
.form-disclaimer{font-size:11px;color:rgba(28,74,58,.35)}

.footer{background:var(--ink);padding:clamp(44px,6vw,72px) var(--pad) clamp(24px,4vw,40px)}
.footer-inner{max-width:1080px;margin:0 auto}
.footer-top{display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:16px;padding-bottom:40px;border-bottom:1px solid rgba(255,255,255,.06);margin-bottom:40px}
.footer-logo{font-family:'Bricolage Grotesque',sans-serif;font-size:16px;font-weight:800;letter-spacing:-0.03em;color:var(--cream);text-decoration:none}
.footer-logo span{color:var(--lime)}
.footer-tagline{font-size:12px;color:rgba(245,240,232,.25);line-height:1.6;text-align:right}
@media(max-width:560px){.footer-tagline{text-align:left}}
.footer-mid{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(24px,4vw,48px);margin-bottom:40px}
@media(max-width:560px){.footer-mid{grid-template-columns:1fr 1fr}}
.footer-col{display:flex;flex-direction:column;gap:10px}
.footer-col-label{font-size:9px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:rgba(245,240,232,.2);margin-bottom:4px}
.footer-link{font-size:12px;color:rgba(245,240,232,.4);text-decoration:none;transition:color .15s}
.footer-link:hover{color:rgba(245,240,232,.75)}
.footer-bottom{padding-top:24px;border-top:1px solid rgba(255,255,255,.05)}
.footer-copy{font-size:10px;color:rgba(245,240,232,.15)}
</style>
